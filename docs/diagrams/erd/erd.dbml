// Vista reducida. El modelo completo esta en sistema_completo.dbml.

Table users {
  id uuid [pk]
  email varchar [unique]
}

Table accounts {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  name varchar
}

Table movements {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  account_id uuid [ref: > accounts.id]
  amount decimal
}

