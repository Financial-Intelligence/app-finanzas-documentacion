// Modelo base actualizado segun FINANCE_APP_DATABASE_AND_API_SPEC.md.

Table users {
  id uuid [pk]
  name varchar
  email varchar [unique]
  password_hash text
  base_currency varchar
  savings_target decimal
  created_at timestamptz
  updated_at timestamptz
}

Table refresh_tokens {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  token_hash text [unique]
  expires_at timestamptz
  revoked_at timestamptz
  created_at timestamptz
}

Table accounts {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  name varchar
  type varchar
  bank_name varchar
  currency varchar
  initial_balance decimal
  current_balance decimal
  credit_limit decimal
  status varchar
  deleted_at timestamptz
  created_at timestamptz
  updated_at timestamptz
}

Table categories {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  type varchar
  name varchar
  color varchar
  icon varchar
  is_active boolean
  deleted_at timestamptz
  created_at timestamptz
  updated_at timestamptz
}

Table subcategories {
  id uuid [pk]
  category_id uuid [ref: > categories.id]
  name varchar
  is_active boolean
  created_at timestamptz
  updated_at timestamptz
}

Table movements {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  type varchar
  status varchar
  amount decimal
  account_id uuid [ref: > accounts.id]
  to_account_id uuid [ref: > accounts.id]
  category_id uuid [ref: > categories.id]
  subcategory_id uuid [ref: > subcategories.id]
  period char
  occurred_on date
  occurred_at timestamptz
  description varchar
  currency varchar
  source_type varchar
  source_id uuid
  deleted_at timestamptz
  created_at timestamptz
  updated_at timestamptz
}

Table recurring_payments {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  type varchar
  name varchar
  amount decimal
  account_id uuid [ref: > accounts.id]
  category_id uuid [ref: > categories.id]
  frequency varchar
  next_date date
  status varchar
  last_confirmed char
  deleted_at timestamptz
  created_at timestamptz
  updated_at timestamptz
}

Table recurring_occurrences {
  id uuid [pk]
  recurring_id uuid [ref: > recurring_payments.id]
  user_id uuid [ref: > users.id]
  period char
  due_date date
  amount decimal
  status varchar
  movement_id uuid [ref: > movements.id]
  confirmed_at timestamptz
  created_at timestamptz
  updated_at timestamptz
}

Table variable_payments {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  type varchar
  name varchar
  amount decimal
  account_id uuid [ref: > accounts.id]
  category_id uuid [ref: > categories.id]
  subcategory_id uuid [ref: > subcategories.id]
  period char
  planned_date date
  status varchar
  movement_id uuid [ref: > movements.id]
  deleted_at timestamptz
}

Table subscriptions {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  name varchar
  amount decimal
  account_id uuid [ref: > accounts.id]
  category_id uuid [ref: > categories.id]
  frequency varchar
  next_renewal date
  status varchar
  last_paid char
  deleted_at timestamptz
}

Table subscription_renewals {
  id uuid [pk]
  subscription_id uuid [ref: > subscriptions.id]
  user_id uuid [ref: > users.id]
  period char
  amount decimal
  status varchar
  movement_id uuid [ref: > movements.id]
  paid_at timestamptz
}

Table loans {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  debtor varchar
  original_amount decimal
  outstanding decimal
  source_account_id uuid [ref: > accounts.id]
  return_account_id uuid [ref: > accounts.id]
  loan_date date
  due_date date
  status varchar
  deleted_at timestamptz
}

Table loan_collections {
  id uuid [pk]
  loan_id uuid [ref: > loans.id]
  user_id uuid [ref: > users.id]
  amount decimal
  collected_on date
  account_id uuid [ref: > accounts.id]
  movement_id uuid [ref: > movements.id]
}

Table debts {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  creditor varchar
  original_amount decimal
  balance decimal
  account_id uuid [ref: > accounts.id]
  receive_account_id uuid [ref: > accounts.id]
  received_on date
  due_date date
  status varchar
  deleted_at timestamptz
}

Table debt_payments {
  id uuid [pk]
  debt_id uuid [ref: > debts.id]
  user_id uuid [ref: > users.id]
  amount decimal
  paid_on date
  account_id uuid [ref: > accounts.id]
  movement_id uuid [ref: > movements.id]
}

Table goals {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  name varchar
  type varchar
  target_amount decimal
  current_amount decimal
  deadline date
  account_id uuid [ref: > accounts.id]
  status varchar
  health varchar
  deleted_at timestamptz
}

Table goal_contributions {
  id uuid [pk]
  goal_id uuid [ref: > goals.id]
  user_id uuid [ref: > users.id]
  amount decimal
  contributed_on date
  from_account_id uuid [ref: > accounts.id]
  to_account_id uuid [ref: > accounts.id]
  movement_id uuid [ref: > movements.id]
}

Table budgets {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  scope varchar
  category_id uuid [ref: > categories.id]
  name varchar
  amount decimal
  period char
}

Table monthly_plans {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  account_id uuid [ref: > accounts.id]
  period char
  carried_over decimal
  recurring_income decimal
  initial_amount decimal
  planned_expenses decimal
  planned_savings decimal
  planned_debts decimal
  expected_result decimal
  real_result decimal
}

